<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0a0a0a">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    <title>{{ page_title }} | {{ shop.name }}</title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    <!-- Tailwind Play CDN (for quick dev, you'll compile it later) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'neutral-950': '#0a0a0a',
              'indigo-600': '#4f46e5',
            },
            animation: {
              'marquee': 'marquee 25s linear infinite',
            },
            keyframes: {
              marquee: {
                '0%': { transform: 'translateX(0%)' },
                '100%': { transform: 'translateX(-50%)' },
              }
            }
          }
        }
      }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', sans-serif; }
      @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }
      .animate-marquee {
        animation: marquee 30s linear infinite;
      }
    </style>
</head>

<body class="bg-neutral-950 text-neutral-100 selection:bg-indigo-600 selection:text-white overflow-x-hidden">
    
    <header class="fixed top-0 w-full z-50 bg-neutral-950/80 backdrop-blur-md border-b border-neutral-800">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <a href="/" class="flex items-center space-x-2 cursor-pointer group">
                <div class="w-8 h-8 bg-indigo-600 rounded-sm rotate-45 flex items-center justify-center transition-transform group-hover:scale-110">
                    <span class="text-white font-bold -rotate-45">C</span>
                </div>
                <span class="text-xl font-bold tracking-tighter uppercase italic">{{ shop.name }}</span>
            </a>

            <nav class="hidden md:flex items-center space-x-8 text-xs font-bold tracking-widest uppercase">
                {% for link in linklists.main-menu.links %}
                    <a href="{{ link.url }}" class="hover:text-indigo-400 transition-colors text-neutral-400 font-bold tracking-[0.2em]">{{ link.title }}</a>
                {% endfor %}
            </nav>

            <div class="flex items-center space-x-4">
                <a href="/cart" class="relative p-2 hover:bg-neutral-800 rounded-full transition-colors group">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-indigo-400"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                    {% if cart.item_count > 0 %}
                    <span class="absolute top-0 right-0 w-5 h-5 bg-indigo-600 text-[10px] flex items-center justify-center rounded-full border-2 border-neutral-950 font-bold">
                        {{ cart.item_count }}
                    </span>
                    {% endif %}
                </a>
            </div>
        </div>
    </header>

    <main id="MainContent" role="main" tabindex="-1">
        {{ content_for_layout }}
    </main>

    <footer class="bg-neutral-950 border-t border-neutral-900 py-20 px-6 mt-20 text-center">
        <div class="max-w-7xl mx-auto space-y-8">
            <div class="flex items-center justify-center space-x-2">
                <div class="w-6 h-6 bg-indigo-600 rounded-sm rotate-45 flex items-center justify-center">
                    <span class="text-white text-[10px] font-bold -rotate-45">C</span>
                </div>
                <span class="font-bold tracking-tighter uppercase italic text-sm">{{ shop.name }}</span>
            </div>
            <p class="text-[10px] font-bold text-neutral-800 uppercase tracking-[0.5em] italic">© {{ 'now' | date: "%Y" }} {{ shop.name }}. POWERED BY CREATIVE.STUDIO.</p>
        </div>
    </footer>

</body>
</html>
